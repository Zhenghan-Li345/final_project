<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpaceColony">

        <!-- Main entry point -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Quarters: view and manage crew in Quarters -->
        <activity
            android:name=".ui.QuartersActivity"
            android:exported="false" />

        <!-- Recruit: create a new crew member -->
        <activity
            android:name=".ui.RecruitCrewActivity"
            android:exported="false" />

        <!-- Simulator: train crew members -->
        <activity
            android:name=".ui.SimulatorActivity"
            android:exported="false" />

        <!-- Mission Control: select crew and launch missions -->
        <activity
            android:name=".ui.MissionControlActivity"
            android:exported="false" />

    </application>

</manifest>
