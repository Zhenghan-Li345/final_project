<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/bg_dark">

    <!-- App title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_subtitle"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp" />

    <!-- Crew counts -->
    <TextView
        android:id="@+id/tv_count_quarters"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/count_quarters_placeholder"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/tv_count_simulator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/count_simulator_placeholder"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/tv_count_mission_control"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/count_mission_control_placeholder"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp" />

    <!-- Recruit button -->
    <Button
        android:id="@+id/btn_recruit"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_recruit"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/btn_primary" />

    <!-- Navigation buttons -->
    <Button
        android:id="@+id/btn_quarters"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_quarters"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/btn_primary" />

    <Button
        android:id="@+id/btn_simulator"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_simulator"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/btn_primary" />

    <Button
        android:id="@+id/btn_mission_control"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_mission_control"
        android:backgroundTint="@color/btn_accent" />

</LinearLayout>
