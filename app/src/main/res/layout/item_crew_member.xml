<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="6dp"
    android:gravity="center_vertical"
    android:background="@color/bg_card">

    <!-- CheckBox for multi-selection -->
    <CheckBox
        android:id="@+id/cb_crew_select"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:focusable="false"
        android:clickable="false" />

    <!-- Crew info column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Crew name -->
        <TextView
            android:id="@+id/tv_crew_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- Specialization -->
        <TextView
            android:id="@+id/tv_crew_specialization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/btn_accent"
            android:layout_marginTop="2dp" />

        <!-- Stats: skill / experience / energy -->
        <TextView
            android:id="@+id/tv_crew_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp" />

        <!-- Current location -->
        <TextView
            android:id="@+id/tv_crew_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</LinearLayout>
